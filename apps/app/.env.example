# Bylineship Wave 3 — operator dashboard environment variables.
# Live secrets live only on the deploy host (never committed).

# Database — Postgres on Coolify (server 144.91.94.91)
DATABASE_URL=postgresql://bylineship:bylineship@localhost:5432/bylineship

# NextAuth
AUTH_SECRET=change-me-to-a-random-64-char-string
AUTH_RESEND_KEY=re_xxxxxxxxxxxx

# Public URLs
NEXT_PUBLIC_APP_URL=https://app.linkedin-b2b-organic.prin7r.com
NEXT_PUBLIC_SITE_URL=https://app.linkedin-b2b-organic.prin7r.com

# Telegram bot
TELEGRAM_BOT_TOKEN=

# Email (Postmark / SES)
POSTMARK_API_KEY=
EMAIL_FROM=writers@linkedin-b2b-organic.prin7r.com

# Sign-off fallback secret (EC-10 — HMAC token for offline sign-offs)
SIGNOFF_SECRET=

# LinkedIn (deferred — Phase 2)
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# Anthropic API (internal: outline summarisation, intent classifier)
ANTHROPIC_API_KEY=

# HubSpot / Pipedrive CRM webhook (per-retainer config stored in DB)
# HUBSPOT_CLIENT_ID=
# HUBSPOT_CLIENT_SECRET=
# PIPEDRIVE_API_KEY=

# Redis (for BullMQ — Phase 1+)
REDIS_URL=redis://localhost:6379

# S3-compatible storage (voice intakes, craft hand-backs)
S3_ENDPOINT=
S3_BUCKET=bylineship-voice-intakes
S3_ACCESS_KEY=
S3_SECRET_KEY=
