# Public app URL used in NOWPayments redirects + IPN callback URLs.
NEXT_PUBLIC_APP_URL=https://linkedin-b2b-organic.prin7r.com
NEXT_PUBLIC_SITE_URL=https://linkedin-b2b-organic.prin7r.com

# NOWPayments hosted invoice + IPN.
# Live keys live only in /opt/prin7r-deploys/linkedin-b2b-organic/.env on the host.
# Reference values are documented in /Users/keer/.nth-kir-keys.env (private).
NOWPAYMENTS_API_KEY=
NOWPAYMENTS_IPN_SECRET=
NOWPAYMENTS_SANDBOX=false

# (Forward-compat; not used by Wave 2 landing) WalletConnect / Reown project.
NEXT_PUBLIC_REOWN_PROJECT_ID=

# (Forward-compat; not used by Wave 2 landing) Plisio direct stablecoin.
PLISIO_API_KEY=

# (Forward-compat; not used by Wave 2 landing) Merchant settlement wallets.
MERCHANT_USDT_TRC20_ADDRESS=
MERCHANT_USDT_ERC20_ADDRESS=
MERCHANT_USDC_ERC20_ADDRESS=
MERCHANT_USDC_POLYGON_ADDRESS=
MERCHANT_USDT_BSC_ADDRESS=
